Material:
  Shader: pbr
  RenderState:
    Blend: Opaque
    Cull: Back
    Depth: Greater
    DepthWrite: true
    ColorWrite: true
  Parameters:
    - Name: u_baseColorFactor
      Type: Color
      Value: [1, 1, 1, 1]
      Range: [0, 1]
    - Name: u_metallicFactor
      Type: Float
      Value: [0, 0, 0, 0]
      Range: [0, 1]
    - Name: u_roughnessFactor
      Type: Float
      Value: [0.956, 0, 0, 0]
      Range: [0, 1]
    - Name: u_emissiveFactor
      Type: Color
      Value: [0, 0, 0, 1]
      Range: [0, 1]
    - Name: u_normalScale
      Type: Float
      Value: [0.143, 0, 0, 0]
      Range: [0, 2]
    - Name: u_occlusionStrength
      Type: Float
      Value: [0, 0, 0, 0]
      Range: [0, 1]
    - Name: s_albedo
      Type: Texture
      Texture: 4475603563681717614
      Stage: 0
    - Name: s_normal
      Type: Texture
      Texture: 0
      Stage: 1
    - Name: s_metalRough
      Type: Texture
      Texture: 0
      Stage: 2
    - Name: s_ao
      Type: Texture
      Texture: 0
      Stage: 3
    - Name: s_emissive
      Type: Texture
      Texture: 0
      Stage: 4