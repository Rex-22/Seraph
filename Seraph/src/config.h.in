#ifndef CONFIG_H_IN_H
#define CONFIG_H_IN_H

// Compile-time defaults used only until a project is opened at runtime:
//   ASSET_PATH               - FileSystem's fallback project asset root.
//   SERAPH_DEFAULT_PROJECT   - the .sproj the editor opens by default (dev).
#define ASSET_PATH "@ASSET_PATH@"
#define SERAPH_DEFAULT_PROJECT "@SERAPH_DEFAULT_PROJECT@"

// Dev-only shader-cook paths (see root CMakeLists.txt). SERAPH_SHADER_INCLUDE_DIRS
// is a ';'-separated list.
#define SERAPH_SHADERC_PATH "@SERAPH_SHADERC_PATH@"
#define SERAPH_SHADER_INCLUDE_DIRS "@SERAPH_SHADER_INCLUDE_DIRS@"

#endif //CONFIG_H_IN_H
