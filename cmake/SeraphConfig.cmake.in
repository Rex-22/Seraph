# SeraphConfig.cmake — generated by the engine build (configure_file @ONLY).
#
# Lets a game project build its Game module against a LOCAL Seraph engine build:
#
#     find_package(Seraph REQUIRED)          # with -DSeraph_DIR=<engine build>
#     add_library(Game SHARED src/...)
#     target_link_libraries(Game PRIVATE Seraph::Seraph)
#
# Paths below are the engine build machine's — valid because the source-SDK model
# has every machine build the engine locally.

set(Seraph_VERSION "@PROJECT_VERSION@")

# Editor / runtime executables — used by a project's RunEditor / packaging targets.
set(SERAPH_EDITOR_EXECUTABLE  "@SERAPH_EDITOR_EXE@")
set(SERAPH_RUNTIME_EXECUTABLE "@SERAPH_RUNTIME_EXE@")
set(SERAPH_ENGINE_BUILD_DIR   "@CMAKE_BINARY_DIR@")

# Source-SDK model: every path in this file is absolute and points at the engine
# build tree on the machine that generated it. If the baked engine binary is not
# where it was built (config copied to another machine, or the engine build tree
# moved/deleted), fail here with an actionable message instead of a confusing
# link-time or downstream error. Rebuild the engine and re-point Seraph_DIR at
# that build's SeraphConfig.cmake.
if(NOT EXISTS "@SERAPH_DYLIB_PATH@")
    message(FATAL_ERROR
        "Seraph: the engine library baked into this SeraphConfig.cmake is missing:\n"
        "    @SERAPH_DYLIB_PATH@\n"
        "SeraphConfig.cmake uses absolute paths from the machine/build tree that "
        "generated it (source-SDK model) and is NOT relocatable. Build the engine "
        "on THIS machine and set -DSeraph_DIR to that build tree.")
endif()

if(NOT TARGET Seraph::Seraph)
    add_library(Seraph::Seraph SHARED IMPORTED)
    set_target_properties(Seraph::Seraph PROPERTIES
        IMPORTED_LOCATION "@SERAPH_DYLIB_PATH@"
        # Every include dir + compile def a Game TU needs (Scene.h pulls entt/glm/
        # Jolt-free physics headers, etc.). GLM_ENABLE_EXPERIMENTAL is required by
        # TransformComponent.h's <glm/gtx/...> includes.
        INTERFACE_INCLUDE_DIRECTORIES "@SERAPH_SDK_INCLUDE_DIRS@"
        # GLM config + the ABI-affecting Jolt defines (JPH_DEBUG_RENDERER,
        # JPH_OBJECT_LAYER_BITS, ...) so a Game module that includes a Jolt-backed
        # header matches the libSeraph it links. See root CMakeLists.
        INTERFACE_COMPILE_DEFINITIONS "@SERAPH_SDK_COMPILE_DEFINITIONS@")
    # Windows links the DLL through its import library.
    if(WIN32)
        set_target_properties(Seraph::Seraph PROPERTIES
            IMPORTED_IMPLIB "@SERAPH_IMPLIB_PATH@")
    endif()
endif()
